# This should be used for platform specific env settings

case "${OSTYPE}" in
  darwin*)
    pathprepend "${HOME}/.local/cmucl/latest/bin" PATH
    pathprepend "${HOME}/.local/sbcl/latest/bin" PATH
    pathprepend "${HOME}/.local/bin" PATH
    pathprepend "/Library/Java/JavaVirtualMachines/graalvm-jdk-21+35.1/Contents/Home/bin" PATH
    pathprepend /opt/homebrew/anaconda3/bin PATH
    pathprepend /opt/homebrew/opt/uutils-coreutils/libexec/uubin PATH
    pathprepend /Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk/usr/lib DYLD_LIBRARY_PATH
    pathprepend /opt/homebrew/lib DYLD_LIBRARY_PATH
    pathprepend "${DYLD_LIBRARY_PATH}" LD_LIBRARY_PATH
    pathprepend "${DYLD_LIBRARY_PATH}" LIBRARY_PATH
    pathprepend /Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk/usr/include CPATH
    pathprepend /opt/homebrew/include CPATH

    export COLIMA_HOME="${XDG_CONFIG_HOME}/colima"

    export NVM_DIR="$HOME/.nvm"
    [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm
    [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion

  ;;
  linux*)
    pathprepend "${HOME}/.local/anaconda3/bin" PATH
    pathprepend "${HOME}/.local/cmucl/latest/bin" PATH
    pathprepend "${HOME}/.local/sbcl/latest/bin" PATH
    pathprepend "${HOME}/.local/emacs/bin" PATH
    pathprepend "${HOME}/bin" PATH
    pathprepend "/usr/local/texlive/2023/bin/x86_64-linux" PATH
  ;;
  *)
  ;;
esac
